      "configuration": "Release"
    },

    {
      "name": "vs2019-x86-debug",
      "configurePreset": "vs2019-x86",
      "configuration": "Debug"
    },
    {
      "name": "vs2019-x86-release",
      "configurePreset": "vs2019-x86",
      "configuration": "Release"
    },
    {
      "name": "vs2019-x64-debug",
      "configurePreset": "vs2019-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs2019-x64-release",
      "configurePreset": "vs2019-x64",
      "configuration": "Release"
    },

    {
      "name": "vslatest-x86-debug",
      "configurePreset": "vslatest-x86",
      "configuration": "Debug"
    },
    {
      "name": "vslatest-x86-release",
      "configurePreset": "vslatest-x86",
      "configuration": "Release"
    },
    {
      "name": "vslatest-x64-debug",
      "configurePreset": "vslatest-x64",
      "configuration": "Debug"
    },
    {
      "name": "vslatest-x64-release",
